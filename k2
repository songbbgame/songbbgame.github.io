<html><head>
<meta charset="utf-8">
<title>Songbbtest</title>

<style>



canvas {
    position: absolute;
    width: 100%;
    z-index: -1;
    margin: 0 auto;
	animation:ac 4s;
-moz-animation:ac 4s;
-webkit-animation:ac 4s; 
-o-animation:ac 3s; 
	filter: blur(1vw);opacity: 0.7;
}

body {
	
    position: absolute;
    width:100%;
    height: 100%;
    content-zooming: none;
	margin: 0px;
	padding: :0px;
	filter: blur(0vw);
	opacity: 1;
	animation:a1 1s;
-moz-animation:a1 1s;
-webkit-animation:a1 1s; 
-o-animation:a1 1s; 
	
	perspective: 25vw;
	
}

html {
	height:100%;
}

	div {
		
		text-align: center;
		color: rgba(248,255,252,1.00);
		width:60%;
		padding: 3% 3%;
		font-size:5vw;
		text-shadow: 0 0 1vw #000;
		border-radius: 7%;
		border:dotted;
		border-width: 1.2vw;
		border-color: rgba(154,227,230,1.00);
		box-shadow: 1vw 1vw 2vw rgba(255,255,255,0.16) inset,
			-1vw -1vw 2vw rgba(0,0,0,0.08) inset;
		background: rgba(126,185,202,1.00);
		
		display:inline-block;
		
		animation:at 4s;
-moz-animation:at 4s;
-webkit-animation:at 4s; 
-o-animation:at 4s; 

		transform-style: preserve-3d;
	}
	
	@keyframes a1
{
0%  {filter: blur(2vw);opacity:0;}
50%  {filter: blur(0.3vw);opacity: 1;}
100%  {filter: blur(0vw);}
}
	@keyframes ac
{
0%  {filter: blur(0vw);opacity:1;}
100%  {filter: blur(1vw);opacity: 0.7;}
}
	@keyframes at
{
	0%  {
		
	border-width: 0vw;
		transform:rotate3d(0.1,1,0.1,80deg) translate3d(5vw,-250vw,30vw);
		
	}
100%  {
	
	border-width: 1.2vw;
	}
}
	
@-moz-keyframes a1
{
0%   {color: rgba(248,255,252,0.00);}
25%  {color: rgba(255,255,255,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
50%  {color: rgba(255,255,255,1.00);text-shadow:0 0 5vw #FFF;}
100% {color: rgba(248,255,252,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
}

@-webkit-keyframes a1
{
0%   {color: rgba(248,255,252,0.00);}
25%  {color: rgba(255,255,255,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
50%  {color: rgba(255,255,255,1.00);text-shadow:0 0 5vw #FFF;}
100% {color: rgba(248,255,252,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
}

@-o-keyframes a1
{
0%   {color: rgba(248,255,252,0.00);}
25%  {color: rgba(255,255,255,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
50%  {color: rgba(255,255,255,1.00);text-shadow:0 0 5vw #FFF;}
100% {color: rgba(248,255,252,1.00);text-shadow:0 0 0vw #rgba(0,0,0,0);}
}
	
</style>

</head>

<body>
	<canvas width="1024" height="2048" id="c1"> </canvas>
	<script>var c=document.getElementById("c1");var ww=c.width;var hh=c.height;var c2=c.getContext("2d");c2.shadowBlur=50;c2.shadowColor='rgba(0,0,0,1.00)';for(i=12;i>=0;i=i-1){for(i2=5;i2>=0;i2=i2-1){c2.shadowColor='rgba(0,0,0,0.6)';c2.shadowBlur=75;var sb=Math.random();sb=Math.ceil(sb*2000)%55+115;var g1=c2.createRadialGradient(256*i2,300*i+150*(i2%2),161,256*i2,300*i+150*(i2%2),211);g1.addColorStop(0,'rgba('+35+','+85+','+sb+',1)');g1.addColorStop(1,'rgba('+25+','+35+','+(sb-22)+',1)');c2.fillStyle=g1;c2.beginPath();c2.arc(256*i2,300*i+150*(i2%2),195,0,6.3,true);c2.closePath();c2.fill()}}
	
	</script>
	
